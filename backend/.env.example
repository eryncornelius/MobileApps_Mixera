# OpenAI: chat/vision (wardrobe JSON detection, mix text) — e.g. gpt-5.4 or gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# images.edit only accepts GPT Image models (e.g. gpt-image-1-mini). Do not set gpt-5.4-mini here.
OPENAI_MIX_PREVIEW_MODEL=gpt-image-1.5
OPENAI_TRYON_MODEL=gpt-image-1.5
WARDROBE_CUTOUT_USE_OPENAI=true
OPENAI_WARDROBE_CUTOUT_MODEL=gpt-image-1.5
OPENAI_WARDROBE_CUTOUT_SIZE=1024x1024
